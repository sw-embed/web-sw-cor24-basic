10 REM DATA / READ / RESTORE DEMO
20 DATA 13, 1, 8, 12, 3, 12, 4, 7, 1, 1
30 PRINT "BUFFER:"
40 FOR I=0 TO 9
50 READ V
60 POKE 512+I, V
70 PRINT V;" ";
80 NEXT I
90 PRINT
100 REM RESTORE REWINDS TO FIRST DATA VALUE
110 RESTORE
120 READ A
130 PRINT "FIRST AGAIN: ";A
140 REM RESTORE <LINE> JUMPS TO A SPECIFIC DATA LINE
150 DATA 100, 200, 300
160 RESTORE 150
170 READ X
180 READ Y
190 PRINT "FROM 150: ";X;" ";Y
200 REM NEGATIVE VALUES WORK TOO
210 DATA -42, -7
220 RESTORE 210
230 READ N
240 READ M
250 PRINT "NEG: ";N;" ";M
260 END
RUN
BYE
