10 REM *** GUESS THE NUMBER (LCG-SEEDED) FOR COR24 BASIC V1 ***
11 REM SPDX-LICENSE-IDENTIFIER: MIT
12 REM (C) 2026 MICHAEL A WRIGHT
13 REM
14 REM COR24 BASIC HAS NO BUILT-IN RND. WE USE A SEEDED LCG SO
15 REM EACH PLAY-THROUGH STARTS FROM THE SAME SEED (42) BUT THE
16 REM TARGET IS NOT THE OBVIOUS LITERAL 42.
17 REM
20 LET R = 42
21 LET R = (R*97 + 1) MOD 8191
22 LET R = (R*97 + 1) MOD 8191
23 LET T = (R MOD 100) + 1
100 PRINT "--- GUESS THE NUMBER ---"
110 PRINT "I AM THINKING OF A NUMBER BETWEEN 1 AND 100."
130 INPUT "YOUR GUESS "; G
140 IF G = T THEN GOTO 200
150 IF G < T THEN PRINT "HIGHER!"
160 IF G > T THEN PRINT "LOWER!"
170 GOTO 130
200 PRINT "CORRECT! YOU GUESSED IT."
210 BYE
RUN
