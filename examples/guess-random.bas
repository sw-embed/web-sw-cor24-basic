13 REM
14 REM REAL ENTROPY VIA REACTION-TIME JITTER. R TICKS UPWARD IN
15 REM A TIGHT LOOP UNTIL THE USER PRESSES ENTER; ITS FINAL VALUE
16 REM DEPENDS ON HUMAN TIMING AND VARIES ACROSS RUNS. NO HOST
17 REM CLOCK INVOLVED -- THE COR24 VM HAS NONE.
18 REM
20 PRINT "RANDOMIZING..."
25 LET K = INKEY
26 IF K >= 0 THEN GOTO 25
30 PRINT "PRESS ENTER TO CONTINUE..."
40 LET R = 0
50 LET R = R + 1
60 LET K = INKEY
70 IF K < 0 THEN GOTO 50
80 LET R = (R*97 + 1) MOD 8191
90 LET R = (R*97 + 1) MOD 8191
100 LET T = (R MOD 100) + 1
105 PRINT ""
110 PRINT "--- GUESS THE NUMBER ---"
115 PRINT "I AM THINKING OF A NUMBER BETWEEN 1 AND 100."
120 INPUT "YOUR GUESS ? "; G
130 IF G = T THEN GOTO 200
140 IF G < T THEN PRINT " - TRY HIGHER!"
150 IF G > T THEN PRINT " - TRY LOWER!"
160 GOTO 120
200 PRINT " - CORRECT! YOU GUESSED IT."
210 BYE
RUN
