130 PRINT "  V=";V;" ISINT=V BAND 1=";V BAND 1
140 PRINT "  V=";V;" TOINT=V SHR 1=";V SHR 1
150 LET P = 8
160 PRINT "  P=";P;" MKINT=(P SHL 1) BOR 1=";(P SHL 1) BOR 1
170 LET Q = 24
