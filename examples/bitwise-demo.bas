10 REM BITWISE OPS DEMO -- SMALLTALK-STYLE TAG-BIT HELPERS
20 PRINT "BAND/BOR/BXOR:"
30 PRINT 12;" BAND ";10;"=";12 BAND 10
40 PRINT 12;" BOR ";10;"=";12 BOR 10
50 PRINT 12;" BXOR ";10;"=";12 BXOR 10
60 PRINT
70 PRINT "SHIFTS:"
80 PRINT 1;" SHL ";4;"=";1 SHL 4
90 PRINT 256;" SHR ";3;"=";256 SHR 3
100 PRINT
110 PRINT "TAGGED-INT HELPERS:"
