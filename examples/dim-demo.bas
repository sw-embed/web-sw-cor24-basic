10 REM DIM INTEGER ARRAY DEMO
20 DIM S(9), C(4)
30 REM SQUARES 0..9 INTO S
40 FOR I=0 TO 9
50 LET S(I) = I*I
60 NEXT I
70 PRINT "SQUARES:"
80 FOR I=0 TO 9
90 PRINT S(I);" ";
100 NEXT I
110 PRINT
120 REM CUBES 0..4 INTO C
130 FOR I=0 TO 4
140 LET C(I) = I*I*I
150 NEXT I
160 PRINT "CUBES:"
170 FOR I=0 TO 4
180 PRINT C(I);" ";
190 NEXT I
200 PRINT
210 REM SCALAR S AND ARRAY S() ARE DISTINCT NAMESPACES
220 LET S = 42
230 PRINT "SCALAR S=";S;" ARRAY S(3)=";S(3)
240 REM EXPRESSIONS AS SUBSCRIPTS
250 LET J = 3
260 PRINT "S(J+2)=";S(J+2)
270 END
RUN
BYE
